# Copy this file to .env and fill in your own personal API keys.
# .env is gitignored -- never commit real keys.
#
# Personal keys only: this is a personal public repo, not Check Point work.
# Never point these at a corporate LLM gateway or credential.

ANTHROPIC_API_KEY=
GROQ_API_KEY=
SERPER_API_KEY=

# Spotify (see brain/spotify.py). Names match what the `spotipy` library
# auto-detects with zero extra config. After filling these in, run
# `uv run python -m brain.spotify` once to authorize (opens a browser) and
# list your available Spotify Connect devices -- if none is ever "active"
# when you ask to play music, add SPOTIFY_DEVICE_NAME=<substring of a device
# name from that list> to .pi-config (not this file), or playback falls back
# to an arbitrary device.
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Mendy's calendar (see brain/gcal.py) -- path to a Google service account's
# downloaded JSON key. See README's "Mendy's calendar & reminders" section
# for the one-time Google Cloud + calendar-sharing setup. The calendar id
# itself goes in .pi-config (MENDY_CALENDAR_ID), not here.
GOOGLE_SERVICE_ACCOUNT_FILE=

# Telegram bot (see telegram_bot_daemon.py) -- token from @BotFather. Which
# chats are allowed to use it goes in .pi-config (TELEGRAM_ALLOWED_CHAT_IDS),
# not here.
TELEGRAM_BOT_TOKEN=
