# Copy this file to .env and fill in your own personal API keys.
# .env is gitignored -- never commit real keys.
#
# Personal keys only: this is a personal public repo, not Check Point work.
# Never point these at a corporate LLM gateway or credential.

ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Spotify (roadmap -- not wired into any code yet). Names match what the
# `spotipy` library auto-detects with zero extra config.
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback
